# BibMedEd Environment Configuration
# Copy to .env and customize as needed.
# All values below are defaults — the app works out of the box without a .env file.

# Optional: PubMed API key for 10 req/s (free registration at https://www.ncbi.nlm.nih.gov/account/)
BIBMEDED_PUBMED_API_KEY=

# PostgreSQL credentials (defaults work with docker-compose)
POSTGRES_USER=bibmeded
POSTGRES_PASSWORD=bibmeded
POSTGRES_DB=bibmeded
